---
layout: compress
permalink: /feed.xml
---

{% capture source %}
<feed xmlns="http://www.w3.org/2005/Atom">
  <id>{{ "/" | absolute_url }}</id>
  <title>{{ site.title }}</title>
  <subtitle>{{ site.description }}</subtitle>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <author>
    <name>{{ site.social.name }}</name>
    <uri>{{ "/" | absolute_url }}</uri>
  </author>
  <link rel="self" type="application/atom+xml" href="{{ "/feed.xml" | absolute_url }}"/>
  <link rel="alternate" type="text/html" hreflang="{{ site.lang | default: "ko-KR" }}"
    href="{{ '/' | absolute_url }}"/>
  <generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator>
  <rights> © {{ 'now' | date: '%Y' }} {{ site.social.name }} </rights>
  <icon>{{ "/assets/img/favicons/favicon.ico" | absolute_url }}</icon>
  <logo>{{ "/assets/img/favicons/favicon-96x96.png" | absolute_url }}</logo>

{% comment %} 색인을 위해 limit을 20 정도로 늘리는 것을 권장합니다 {% endcomment %}
{% for post in site.posts limit: 20 %}
  {% assign post_absolute_url = post.url | absolute_url %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ post_absolute_url }}" rel="alternate" type="text/html" title="{{ post.title | xml_escape }}" />
    <published>{{ post.date | date_to_xmlschema }}</published>
  {% if post.last_modified_at %}
    <updated>{{ post.last_modified_at | date_to_xmlschema }}</updated>
  {% else %}
    <updated>{{ post.date | date_to_xmlschema }}</updated>
  {% endif %}
    <id>{{ post_absolute_url }}</id>
    <content type="html" xml:base="{{ post_absolute_url }}">{{ post.content | xml_escape }}</content>
    <author>
      <name>{{ post.author | default: site.social.name }}</name>
    </author>

  {% if post.categories %}
    {% for category in post.categories %}
    <category term="{{ category }}" />
    {% endfor %}
  {% endif %}

  {% if post.summary %}
    <summary>{{ post.summary | strip | xml_escape }}</summary>
  {% else %}
    <summary type="html">
      {% comment %} post.content에서 직접 추출하도록 수정 {% endcomment %}
      {{ post.content | strip_html | truncate: 400 | xml_escape }}
    </summary>
  {% endif %}

  </entry>
{% endfor %}
</feed>
{% endcapture %}
{{ source | replace: '&', '&amp;' }}
